{
  "name": "@hoster/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./migrate": {
      "types": "./src/migrate.ts",
      "import": "./src/migrate.ts"
    },
    "./seed": {
      "types": "./src/seed.ts",
      "import": "./src/seed.ts"
    }
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "generate:pg": "DB_DIALECT=pg drizzle-kit generate",
    "generate:mysql": "DB_DIALECT=mysql drizzle-kit generate",
    "generate:sqlite": "DB_DIALECT=sqlite drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hoster/types": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.38.4",
    "mysql2": "^3.17.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.12.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
