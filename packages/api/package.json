{
  "name": "@fleet/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --external @aws-sdk/client-s3 --external @google-cloud/storage",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@fleet/db": "workspace:*",
    "@fleet/types": "workspace:*",
    "@hono/node-server": "^1.13.8",
    "@hono/node-ws": "^1.1.1",
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.9.44",
    "argon2": "^0.41.1",
    "bullmq": "^5.69.3",
    "dockerode": "^4.0.4",
    "hono": "^4.7.4",
    "ioredis": "^5.4.2",
    "jose": "^6.0.11",
    "nodemailer": "^8.0.1",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "ssh2": "^1.17.0",
    "stripe": "^17.5.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^3.3.34",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.38.4",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
