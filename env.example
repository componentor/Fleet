# Hoster Environment Configuration
# Copy this to .env and fill in your values

# Database (sqlite, postgres, mysql)
DB_DIALECT=sqlite
DATABASE_URL=postgresql://hoster:hoster@localhost:5432/hoster

# Valkey (Redis-compatible)
VALKEY_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# API
PORT=3000
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5173/auth/callback?provider=github

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/callback?provider=google

# Domain
PLATFORM_DOMAIN=localhost
PLATFORM_URL=http://localhost:5173

# Email (choose provider: smtp, resend, postmark, sendgrid)
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@example.com

# SMTP settings (if EMAIL_PROVIDER=smtp)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Cloudflare (optional)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Docker
DOCKER_SOCKET=/var/run/docker.sock
REGISTRY_URL=localhost:5000
