# ── Core ──
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# ── Security ──
JWT_SECRET=                    # Generate: openssl rand -hex 32
ENCRYPTION_KEY=                # Generate: openssl rand -hex 32 (64 hex characters)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Database ──
DB_DIALECT=pg
DATABASE_URL=postgresql://fleet:your-password@postgres:5432/fleet
PG_POOL_MAX=20

# ── Valkey/Redis ──
VALKEY_URL=redis://:yourpassword@valkey:6379

# ── Stripe (billing) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email ──
EMAIL_PROVIDER=smtp            # smtp or resend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com
# RESEND_API_KEY=
# RESEND_FROM=

# ── OAuth (optional) ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── DNS ──
NAMESERVERS=ns1.yourdomain.com,ns2.yourdomain.com

# ── Cloudflare (optional) ──
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Docker ──
DOCKER_SOCKET=/var/run/docker.sock
REGISTRY_URL=registry:5000

# ── Docker Compose ──
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com
POSTGRES_PASSWORD=             # Generate: openssl rand -hex 16
