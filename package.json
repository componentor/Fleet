{
  "name": "fleet",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-tenant PaaS hosting control panel on Docker Swarm",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "cpu-features",
      "esbuild",
      "ssh2",
      "protobufjs",
      "vue-demi"
    ]
  },
  "scripts": {
    "dev": "turbo run dev 2>/dev/null || true",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @fleet/db generate",
    "db:migrate": "pnpm --filter @fleet/db migrate",
    "db:push": "pnpm --filter @fleet/db push"
  },
  "devDependencies": {
    "turbo": "^2.8.9",
    "vitest": "^4.0.18"
  }
}
