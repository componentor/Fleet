FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.4.1 --activate
RUN apk add --no-cache nfs-utils docker-cli
WORKDIR /app

FROM base AS build
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/types/package.json ./packages/types/
COPY packages/agent/package.json ./packages/agent/
RUN pnpm install --frozen-lockfile
COPY packages/types ./packages/types
COPY packages/agent ./packages/agent
COPY tsconfig.base.json ./
RUN pnpm --filter @fleet/agent exec tsup src/index.ts --format esm
RUN pnpm --filter @fleet/agent deploy --legacy --prod /app/production

FROM base AS runner
ENV NODE_ENV=production
COPY --from=build /app/production ./
COPY --from=build /app/packages/agent/dist ./dist
CMD ["node", "dist/index.js"]
